#!/usr/bin/env bash
# Project-local launcher — does not require a global install.
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if command -v bun >/dev/null 2>&1; then
  exec bun "${ROOT}/src/index.ts" "$@"
fi

echo "llm-usage: bun not found. Install bun, or put it on PATH." >&2
exit 127
